{
  "name": "celitech-sdk",
  "version": "2.0.1",
  "description": "Welcome to the CELITECH API documentation!  Useful links: [Homepage](https://www.celitech.com) | [Support email](mailto:support@celitech.com) | [Blog](https://www.celitech.com/blog/)",
  "source": "./src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "browser": "./dist/index.js",
  "unpkg": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "tsc --noEmit",
    "build": "tsup-node src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "chmod +x ./scripts/prepublish.sh && ./scripts/prepublish.sh && npm run build",
    "test-example": "cd examples && tsc --noEmit"
  },
  "keywords": [
    "typescript",
    "sdk",
    "api",
    "client"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "author": "CELITECH",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Celitech/CelitechSDKTypeScript.git"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "5.3.3",
    "@types/node": "^22.14.0",
    "tsup": "^6.7.0"
  },
  "dependencies": {
    "zod": "3.22.0"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  }
}
